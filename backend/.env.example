# Google Gemini API key (Required for voice & vision analysis)
GEMINI_API_KEY=

# OpenRouter API key (Optional fallback for other LLM models)
OPENROUTER_API_KEY=

# Groq API key (Optional fast inference)
GROQ_API_KEY=

# LiveKit Web RTC Connection Credentials (Required for dashboard voice link)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Local Agent configuration
AGENT_NAME=jarvis
JARVIS_API_KEY=
